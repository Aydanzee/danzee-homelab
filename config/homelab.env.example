# Copy to config/homelab.env and edit locally.
# Never commit the real file.

LAB_HOSTNAME=danzee-lab
LINUX_USER=your-linux-user

# Example only. Use the host's real reserved LAN address and trusted LAN CIDR.
LAN_IP=192.168.1.50
LAN_CIDR=192.168.1.0/24

# Service ports
PORTAINER_PORT=9443
UPTIME_KUMA_PORT=3001
AXIOM_LOCAL_PORT=8088
K3S_DEMO_NODEPORT=30080

# Versions tested on the reference homelab.
K3S_VERSION=v1.35.5+k3s1
OLLAMA_VERSION=0.30.8

# Default k3s pod and service networks.
K3S_POD_CIDR=10.42.0.0/16
K3S_SERVICE_CIDR=10.43.0.0/16

# Local model suitable for a low-memory CPU-only host.
OLLAMA_MODEL=qwen2.5:0.5b

# Compose installation
HOMELAB_DIR=/opt/homelab

# Backup defaults
USB_MOUNT=/mnt/danzee-backup
BACKUP_TIME=02:30:00
KEEP_BACKUPS=14

# Optional private app source. Leave blank to skip Axiom Local deployment.
AXIOM_LOCAL_REPO=
AXIOM_LOCAL_DIR=/opt/axiom-local
